# ===========================================
# 必須 (これらが未設定だと起動失敗します)
# ===========================================

# PWA(Web UI) のパスワード — ログイン画面で入力する任意の文字列
PWA_PASSWORD=

# PWAクライアントが使用するAPIキー — 任意の長い乱数文字列を生成
PWA_API_KEY=

# ===========================================
# Google サービス連携 (実質必須)
# ===========================================

# OAuth で取得した token.json の中身を JSON 文字列として埋め込む
# (Render 等で永続ストレージが無い場合に利用)
GOOGLE_TOKEN_JSON=

# Vault ルートフォルダの Google Drive ID
GOOGLE_DRIVE_FOLDER_ID=

# 連携するカレンダー ID (デフォルト: primary)
GOOGLE_CALENDAR_ID=primary

# Books / Places API キー (任意)
GOOGLE_BOOKS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ===========================================
# AI / LLM
# ===========================================

GEMINI_API_KEY=

# ===========================================
# 通知・連携
# ===========================================

# Discord Bot トークン (本リポジトリは現在 Discord 接続を使用していません)
DISCORD_BOT_TOKEN=

# Fitbit OAuth (健康データ連携をする場合)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_ACCESS_TOKEN=
FITBIT_REFRESH_TOKEN=

# ===========================================
# 位置情報・地域設定
# ===========================================

# "<lat>,<lng>" 形式 (例: "35.6895,139.6917")
HOME_COORDINATES=
WORK_COORDINATES=

# 表示用の地域名 / 気象庁エリア名 (天気予報)
LOCATION_NAME=
JMA_AREA_NAME=

# ===========================================
# サーバー設定
# ===========================================

# 既定 10000
PORT=10000
